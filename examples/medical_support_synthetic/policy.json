{
  "schema": "qsolai.policy/v1",
  "policy_id": "medical-support-synthetic-policy",
  "execution_profile": "SIM_ONLY",
  "support_profile": "MEDICAL_SUPPORT",
  "human_approval_required": true,
  "required_independent_backends": 2,
  "max_observation_bytes": 65536,
  "worker_timeout_ms": 2000,
  "capability_grants": [
    {
      "schema": "qsolai.capability-grant/v1",
      "grant_id": "mock-only",
      "execution_profile": "SIM_ONLY",
      "allowed_adapters": ["MOCK"],
      "allow_subprocess": false,
      "argv": [],
      "environment": {}
    }
  ],
  "agents": [
    {
      "schema": "qsolai.agent/v1",
      "agent_id": "medical-support-a",
      "backend_id": "synthetic-medical-backend-a",
      "adapter": "MOCK",
      "roles": ["SUBSTRATE", "GENERATOR", "CRITIC", "ADVERSARY", "CONSTRAINT_AUDITOR", "SYNTHESIS_CANDIDATE"],
      "capability_grant_id": "mock-only",
      "mock_response": {
        "protocol": "qsolai.worker-result/v1",
        "summary": "Synthetic cautious support view",
        "claims": [
          {
            "schema": "qsolai.claim/v1",
            "claim_id": "review-view-a",
            "text": "The synthetic symptom pattern warrants clinician review.",
            "polarity": "SUPPORT",
            "evidence_references": [
              {
                "schema": "qsolai.evidence-reference/v1",
                "requirement_id": "synthetic-clinical-record",
                "record_id": "synthetic-note-001",
                "source_date": "2026-01-01",
                "jurisdiction": null
              }
            ]
          }
        ],
        "uncertainties": ["The record and all clinical facts are invented."],
        "constraint_report": {"satisfied": ["medical-disclaimer"], "possibly_violated": []},
        "proposed_actions": [],
        "answer": "This synthetic decision-support output is not medical advice. The invented record warrants human clinical review, and no diagnosis or treatment is authorized."
      }
    },
    {
      "schema": "qsolai.agent/v1",
      "agent_id": "medical-support-b",
      "backend_id": "synthetic-medical-backend-b",
      "adapter": "MOCK",
      "roles": ["SUBSTRATE", "GENERATOR", "CRITIC", "ADVERSARY", "CONSTRAINT_AUDITOR", "SYNTHESIS_CANDIDATE"],
      "capability_grant_id": "mock-only",
      "mock_response": {
        "protocol": "qsolai.worker-result/v1",
        "summary": "Synthetic dissenting support view",
        "claims": [
          {
            "schema": "qsolai.claim/v1",
            "claim_id": "review-view-b",
            "text": "The synthetic symptom pattern warrants clinician review.",
            "polarity": "DENY",
            "evidence_references": [
              {
                "schema": "qsolai.evidence-reference/v1",
                "requirement_id": "synthetic-clinical-record",
                "record_id": "synthetic-note-001",
                "source_date": "2026-01-01",
                "jurisdiction": null
              }
            ]
          }
        ],
        "uncertainties": ["The synthetic evidence is insufficient to resolve the disagreement."],
        "constraint_report": {"satisfied": ["medical-disclaimer"], "possibly_violated": []},
        "proposed_actions": [],
        "answer": "This is not medical advice. The invented evidence does not resolve whether review is warranted; a human reviewer retains all authority."
      }
    }
  ],
  "style": {
    "schema": "qsolai.style/v1",
    "required_phrases": ["not medical advice"],
    "forbidden_phrases": [],
    "max_output_bytes": 32768,
    "max_repeated_line_count": 2
  },
  "forbidden_authority_phrases": ["diagnosis is certain", "treatment is guaranteed"],
  "anti_repetition_enabled": false,
  "maximum_attempts": 16,
  "ranking": ["required_constraint_passes", "evidence_supported_claims", "deterministic_verifier_passes", "unsupported_claim_count", "contradiction_count", "risk_flag_count", "style_violation_count", "excess_output_bytes", "candidate_sha256"]
}
