      "allowed_adapters": ["MOCK"],
      "allow_subprocess": false,
      "argv": [],
      "environment": {}
    }
  ],
  "agents": [
    {
      "schema": "qsolai.agent/v1",
      "agent_id": "supported-researcher",
      "backend_id": "synthetic-research-backend-a",
