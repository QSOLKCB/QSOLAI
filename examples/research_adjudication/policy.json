{
  "schema": "qsolai.policy/v1",
  "policy_id": "research-adjudication-policy",
  "execution_profile": "SIM_ONLY",
  "support_profile": "NONE",
  "human_approval_required": false,
  "required_independent_backends": 1,
  "max_observation_bytes": 65536,
