              {
                "schema": "qsolai.evidence-reference/v1",
                "requirement_id": "synthetic-study",
                "record_id": "paper-A",
                "source_date": "2026-07-01",
                "jurisdiction": null
              }
            ]
          }
        ],
        "uncertainties": ["The evidence is synthetic and supports no generalization."],
        "constraint_report": {"satisfied": ["bounded-language"], "possibly_violated": []},
        "proposed_actions": [],
        "answer": "The synthetic record supports only its bounded test result; it does not establish a general scientific conclusion."
      }
    },
    {
      "schema": "qsolai.agent/v1",
      "agent_id": "unsupported-researcher",
      "backend_id": "synthetic-research-backend-b",
      "adapter": "MOCK",
      "roles": ["SUBSTRATE", "GENERATOR", "CRITIC", "ADVERSARY", "CONSTRAINT_AUDITOR", "SYNTHESIS_CANDIDATE"],
      "capability_grant_id": "mock-only",
      "mock_response": {
        "protocol": "qsolai.worker-result/v1",
        "summary": "Unsupported synthetic generalization",
        "claims": [
          {
            "schema": "qsolai.claim/v1",
            "claim_id": "unsupported-result",
            "text": "The synthetic result applies universally.",
            "polarity": "SUPPORT",
            "evidence_references": []
          }
        ],
        "uncertainties": [],
        "constraint_report": {"satisfied": ["bounded-language"], "possibly_violated": []},
        "proposed_actions": [],
        "answer": "The synthetic result applies universally."
      }
    }
  ],
  "style": {
    "schema": "qsolai.style/v1",
    "required_phrases": [],
    "forbidden_phrases": [],
    "max_output_bytes": 32768,
    "max_repeated_line_count": 2
  },
  "forbidden_authority_phrases": ["applies universally"],
  "anti_repetition_enabled": false,
  "maximum_attempts": 16,
  "ranking": ["required_constraint_passes", "evidence_supported_claims", "deterministic_verifier_passes", "unsupported_claim_count", "contradiction_count", "risk_flag_count", "style_violation_count", "excess_output_bytes", "candidate_sha256"]
